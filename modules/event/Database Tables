-- 1. กิจกรรมหลัก
events (
  event_id        PK
  event_code      unique
  event_name
  event_type      BOOTH/MEETING/ONLINE/HYBRID/OTHER
  event_date
  end_date
  location
  poster_url
  max_attendees
  status          DRAFT/CONFIRMED/ONGOING/DONE/CANCELLED
  created_by      → users.user_id
  assigned_to     → users.user_id
  created_at
)

-- 2. คำขอจัดงานจากแผนกอื่น
event_requests (
  request_id      PK
  requested_by    → users.user_id
  dept_id         → departments.dept_id
  event_name
  requested_date
  detail
  status          PENDING/APPROVED/REJECTED
  reviewed_by     → users.user_id
  created_at
)

-- 3. Log/Update/แจ้งเหตุการณ์
event_logs (
  log_id          PK
  event_id        → events.event_id
  user_id         → users.user_id
  log_type        UPDATE/NOTE/REQUEST/ISSUE
  message
  attachment_url
  created_at
)

-- 4. ห้องประชุม
meeting_rooms (
  room_id         PK
  room_code       unique
  room_name
  branch          ← สาขาใหญ่/ย่อย
  capacity
  facilities      JSON
  is_active
)

-- 5. การจองห้อง
room_bookings (
  booking_id      PK
  event_id        → events.event_id
  room_id         → meeting_rooms.room_id
  booking_date
  start_time
  end_time
  booked_by       → users.user_id
  status          PENDING/CONFIRMED/CANCELLED
)

-- 6. Supplier ที่ใช้ต่องาน
event_suppliers (
  ev_supplier_id  PK
  event_id        → events.event_id
  supplier_id     → suppliers.supplier_id
  service_type    HOTEL/FOOD/PHOTO/SPEAKER/FLOWER/SHIRT/OTHER
  amount
  status          PENDING/ORDERED/DELIVERED/CANCELLED
)

-- 7. งบประมาณต่องาน
event_budget (
  budget_id       PK
  event_id        → events.event_id
  budget_total
  spent_amount
  approved_by     → users.user_id
)

-- 8. ผู้เข้าร่วมงาน
event_attendees (
  attendee_id     PK
  event_id        → events.event_id
  name
  phone
  email
  attend_type     ONLINE/OFFLINE
  ticket_no
  paid_amount
  checked_in      boolean
  check_in_at
)

-- 9. ตาราง Media หลังงาน
event_media (
  media_id        PK
  event_id        → events.event_id
  media_type      EDIT/POST/PHOTO_DELIVER
  detail
  assigned_to     → users.user_id
  due_date
  status          PENDING/IN_PROGRESS/DONE
)